{
    "name": "specter-qwen-hud",
    "displayName": "SPECTER QWEN HUD",
    "description": "Real-time tactical monitoring for Qwen-MCP",
    "version": "1.1.4",
    "publisher": "specter",
    "repository": {
        "type": "git",
        "url": "https://github.com/blueinfiniti/qwen-mcp"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "icon": "assets/icon.png",
    "main": "./extension.js",
    "files": [
        "extension.js",
        "dist/**",
        "assets/**"
    ],
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "specter-qwen-hud-explorer",
                    "title": "Specter Qwen HUD",
                    "icon": "assets/icon.svg"
                }
            ]
        },
        "views": {
            "specter-qwen-hud-explorer": [
                {
                    "type": "webview",
                    "id": "specter-qwen-cockpit-v1",
                    "name": "Cockpit",
                    "icon": "assets/icon.svg"
                }
            ]
        }
    }
}